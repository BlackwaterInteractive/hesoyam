{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "Hesoyam",
  "version": "0.1.0",
  "identifier": "gg.hesoyam.agent",
  "build": {
    "frontendDist": "./ui",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "withGlobalTauri": true,
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": false
    },
    "windows": [
      {
        "title": "Hesoyam",
        "label": "main",
        "url": "index.html",
        "width": 420,
        "height": 320,
        "resizable": false,
        "visible": true,
        "center": true,
        "decorations": true
      },
      {
        "title": "Hesoyam Settings",
        "label": "settings",
        "url": "settings.html",
        "width": 480,
        "height": 600,
        "resizable": false,
        "visible": false,
        "center": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    }
  },
  "plugins": {
    "autostart": {
      "macOSExtraArgs": ["--flag1", "--flag2"]
    }
  }
}
